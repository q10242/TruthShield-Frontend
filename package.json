{
  "name": "truth-shield-web",
  "private": true,
  "description": "Open-source news credibility frontend, public Truth Hub, iframe panels, and browser extensions for TruthShield.",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check:extension": "node scripts/check-extension-release.mjs dist/extension-package",
    "package:extension:local": "node scripts/package-extension-local.mjs",
    "package:extension": "node scripts/package-extension.mjs",
    "package:extension:firefox": "node scripts/package-extension-firefox.mjs",
    "package:extension:safari-source": "node scripts/package-extension-safari-source.mjs",
    "package:extension:safari": "node scripts/package-extension-safari.mjs",
    "build:release": "npm run package:extension && npm run package:extension:firefox && npm run package:extension:safari-source && npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "vite": "^8.0.10"
  }
}
